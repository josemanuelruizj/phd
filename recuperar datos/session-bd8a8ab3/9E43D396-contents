```{r}
characteristics <- read.csv('/users/genomics/josema/multiome/Human_batch1/outs/per_barcode_metrics.csv')

mapped_metadata <- characteristics %>%  
  dplyr::filter(is_cell==1) %>% 
  dplyr::select(barcode,gex_mapped_reads, gex_conf_exonic_reads,gex_conf_intronic_reads) %>% 
  column_to_rownames('barcode') %>% 
  dplyr::mutate(Nuclear_fraction=gex_conf_intronic_reads/(gex_conf_intronic_reads+gex_conf_exonic_reads)) 
```

```{r}
human_d30_unfiltered@meta.data <-  cbind(human_d30_unfiltered@meta.data,mapped_metadata[rownames(human_d30_unfiltered@meta.data),]) 
DefaultAssay(human_d30_unfiltered) <- "RNA"
human_d30_unfiltered[["percent.mt"]] <- PercentageFeatureSet(human_d30_unfiltered, pattern = "^MT-")

```

```{r}
human_d30_filtered <- subset(
  x = human_d30_unfiltered,
  subset = nFeature_RNA  > 200 &
    nFeature_RNA < 5000 &
    percent.mt < 5 & 
    nCount_ATAC < 100000 &
    nCount_RNA < 25000 &
    nCount_ATAC > 1800 &
    nCount_RNA > 1000 &
    nucleosome_signal < 2 &
    TSS.enrichment > 1
)
```


```{r}
DefaultAssay(human_d30_unfiltered) <- "RNA"
human_d30_unfiltered <- NormalizeData(human_d30_unfiltered)
human_d30_unfiltered <- FindVariableFeatures(human_d30_unfiltered)
human_d30_unfiltered <- ScaleData(human_d30_unfiltered)
human_d30_unfiltered <- RunPCA(human_d30_unfiltered)
human_d30_unfiltered <- RunUMAP(human_d30_unfiltered, dims = 1:30)

DefaultAssay(human_d30_unfiltered) <- "ATAC"
human_d30_unfiltered <- RunTFIDF(human_d30_unfiltered)
human_d30_unfiltered <- FindTopFeatures(human_d30_unfiltered, min.cutoff = "q0")
human_d30_unfiltered <- RunSVD(human_d30_unfiltered)
# We exclude the first dimension as this is typically correlated with sequencing depth
human_d30_unfiltered <- RunUMAP(human_d30_unfiltered, reduction = "lsi", dims = 2:30, reduction.name = "umap.atac", reduction.key = "atacUMAP_")
```


```{r}
DefaultAssay(human_d30_filtered) <- "RNA"
human_d30_filtered <- NormalizeData(human_d30_filtered)
human_d30_filtered <- FindVariableFeatures(human_d30_filtered)
human_d30_filtered <- ScaleData(human_d30_filtered, features=rownames(human_d30_filtered))
human_d30_filtered <- RunPCA(human_d30_filtered)
human_d30_filtered <- FindNeighbors(human_d30_filtered, dims = 1:10)
human_d30_filtered <- FindClusters(human_d30_filtered, resolution = 0.5)
human_d30_filtered <- RunUMAP(human_d30_filtered, dims = 1:30)

DefaultAssay(human_d30_filtered) <- "ATAC"
human_d30_filtered <- RunTFIDF(human_d30_filtered)
human_d30_filtered <- FindTopFeatures(human_d30_filtered, min.cutoff = "q0")
human_d30_filtered <- RunSVD(human_d30_filtered)
# We exclude the first dimension as this is typically correlated with sequencing depth
human_d30_filtered <- RunUMAP(human_d30_filtered, reduction = "lsi", dims = 2:30, reduction.name = "umap.atac", reduction.key = "atacUMAP_")
```

