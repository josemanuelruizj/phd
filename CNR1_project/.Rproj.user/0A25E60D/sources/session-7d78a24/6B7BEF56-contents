  # All combos just for the filtered data
  all_combos <- expand_grid(
    Dataset = unique(data_filtered$Dataset),
    com_class = valid_classes
  )

  # Counts and percents
  df_plot <- data_filtered %>%
    count(Dataset, com_class) %>%
    group_by(Dataset) %>%
    mutate(percent = n / sum(n)) %>%
    ungroup()

  # Fill in missing combos
  df_complete <- all_combos %>%
    left_join(df_plot, by = c("Dataset", "com_class"))

  # Plot
  ggplot(df_complete, aes(x = com_class, y = Dataset, fill = percent)) +
    geom_tile(color = "white") +
