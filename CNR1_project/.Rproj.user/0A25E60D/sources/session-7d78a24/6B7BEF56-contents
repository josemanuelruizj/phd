# la manno

CNR1_manno <- read.csv('/home/josema/Downloads/manno_Cannabinoids.csv')
Manno_mouse_meta <- read.csv('/home/josema/Downloads/manno_metadata.csv') %>%  select(X, Subclass, Tissue)


age_order_manno=c('e7.0', 'e8.0', 'e8.5', 'e9.0', 'e10.0',
  'e11.0', 'e12.0', 'e12.5', 'e13.0','e13.5',
  'e14.0', 'e14.5', 'e15.0','e15.5', 'e16.0',
  'e16.25','e16.5', 'e17.0', 'e17.5','e18.0')

