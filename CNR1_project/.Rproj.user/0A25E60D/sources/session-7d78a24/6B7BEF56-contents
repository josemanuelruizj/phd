  inner_join(Manno_mouse_meta, by=c('Cell_Id'='X')) %>% 
  inner_join(manno_coordinates, by=c('Cell_Id' = '...1')) %>% 
  mutate(com_class= case_when(Class == 'Neuron' ~ 'NEU',
                              Class == 'Neuroblast' ~ 'IPC',
                              Class %in% c('Radial glia', 'Neural tube','Neural crest') ~ 'PROG',
                              Class %in% c('Oligodendrocyte') ~ 'OLIG',
                              TRUE ~ 'Other'),
         Age=factor(Age, levels=age_order_manno)) %>% 
  mutate(UMAP1=umap_1, UMAP2=umap_2) %>% 
  rename(Area=Tissue) %>% 
  pivot_longer(cols = -c(Cell_Id, Age, Class, Subclass, com_class, Area, UMAP1, UMAP2), names_to = 'Gene', values_to ='Expression')



Manno %>% 
  filter(Gene=='Cnr1') %>% 
  ggplot(aes(x = UMAP1, y = UMAP2, z = Expression)) +
  stat_summary_hex(bins = 50, fun = mean) +
