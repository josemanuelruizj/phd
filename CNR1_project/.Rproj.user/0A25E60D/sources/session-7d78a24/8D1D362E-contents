# -----------------------------
# Helper functions
# -----------------------------

collapse_orthology <- function(x) {
  x <- as.character(x)
  x <- x[!is.na(x) & x != "" & x != "NA"]
  
  # BioMart can return many2one; for this analysis we merge it
  # into the one2many / non-one2one category
  x[x == "ortholog_many2one"] <- "ortholog_one2many"
  
  if (length(x) == 0) {
    return("NA")
  }
  
  if (any(x == "ortholog_many2many")) {
    return("ortholog_many2many")
  }
  
  if (any(x == "ortholog_one2many")) {
    return("ortholog_one2many")
  }
  
  if (all(x == "ortholog_one2one")) {
    return("ortholog_one2one")
  }
  
  return(paste(sort(unique(x)), collapse = ";"))
}


cumulative_orthology <- function(x) {
  x <- as.character(x)
  
  if (any(is.na(x) | x == "" | x == "NA")) {
    return("NA")
  }
  
  x[x == "ortholog_many2one"] <- "ortholog_one2many"
  
  if (all(x == "ortholog_one2one")) {
    return("ortholog_one2one")
  }
  
  if (any(x == "ortholog_many2many")) {
    return("ortholog_many2many")
  }
  
  return("ortholog_one2many")
}

