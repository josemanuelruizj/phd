# -----------------------------
# Function to safely query one species
# -----------------------------

query_species_orthologs <- function(sp_row, gene_chunks, mart, outdir) {
  
  sp <- sp_row
  
  message("\n==============================")
  message("Species: ", sp$label)
  message("==============================")
  
  orth_col <- paste0(sp$prefix, "_homolog_orthology_type")
  ens_col  <- paste0(sp$prefix, "_homolog_ensembl_gene")
  name_col <- paste0(sp$prefix, "_homolog_associated_gene_name")
  
  available_attrs <- listAttributes(mart)$name
  
  attrs <- c(
    "ensembl_gene_id",
    "external_gene_name",
    orth_col,
    ens_col,
    name_col
  )
  
  attrs <- attrs[attrs %in% available_attrs]
  
  missing_attrs <- setdiff(
    c("ensembl_gene_id", "external_gene_name", orth_col, ens_col),
    attrs
  )
  
  if (length(missing_attrs) > 0) {
    warning(
      "Skipping ",
      sp$label,
      ". Missing attributes: ",
      paste(missing_attrs, collapse = ", ")
    )
    return(NULL)
  }
  
  species_file <- file.path(
    outdir,
    paste0("orthologs_", sp$species, ".csv")
  )
  
  if (file.exists(species_file)) {
    message("Already exists, reading: ", species_file)
    return(read.csv(species_file))
  }
  
  chunk_results <- vector("list", length(gene_chunks))
  
  for (i in seq_along(gene_chunks)) {
    
    message("  Chunk ", i, "/", length(gene_chunks))
    
    chunk_result <- tryCatch(
      {
        getBM(
          attributes = attrs,
          filters = "ensembl_gene_id",
          values = gene_chunks[[i]],
          mart = mart,
          curl = curl_handle
        )
      },
      error = function(e) {
        message("    Failed chunk ", i, ": ", e$message)
        NULL
      }
    )
    
    chunk_results[[i]] <- chunk_result
    
    Sys.sleep(0.2)
  }
  
  species_df <- bind_rows(chunk_results)
  
  species_df[species_df == ""] <- NA
  
  write.csv(species_df, species_file, row.names = FALSE)
  
  species_df
}

