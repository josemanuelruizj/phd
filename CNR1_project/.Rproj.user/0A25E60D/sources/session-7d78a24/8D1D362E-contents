make_alluvial_plot <- function(wide_df, axes, title, outfile, width = 10, height = 5) {
  
  plot_df <- wide_df %>%
    mutate(across(all_of(axes), ~ ifelse(is.na(.x), "NA", as.character(.x)))) %>%
    mutate(across(all_of(axes), ~ gsub("^ortholog_", "", .x))) %>%
    count(across(all_of(axes)), name = "n")
  
  lodes_data <- ggalluvial::to_lodes_form(
    plot_df,
    axes = axes,
    key = "axis",
    value = "value"
  )
  
  p <- ggplot(
    lodes_data,
    aes(
      x = axis,
      stratum = value,
      alluvium = alluvium,
      y = n,
      label = value
    )
  ) +
    geom_alluvium(aes(fill = value), alpha = 0.75) +
    geom_stratum(aes(fill = value), color = "gray60") +
    geom_text(
      stat = "stratum",
      aes(label = after_stat(stratum)),
      size = 3
    ) +
    scale_x_discrete(
      limits = axes,
      expand = c(0.08, 0.08)
    ) +
    labs(
      title = title,
      x = NULL,
      y = "Genes"
    ) +
    theme_void() +
    theme(
      plot.title = element_text(face = "bold"),
      axis.text.x = element_text(angle = 45, hjust = 1),
      legend.position = "none"
    )
  
  ggsave(
    outfile,
    p,
    device = "pdf",
    width = width,
    height = height
  )
  
  return(p)
}

