# -----------------------------
# Connect to Ensembl using mirrors
# -----------------------------

connect_ensembl <- function() {
  mirrors <- c("www", "useast", "uswest", "asia")
  
  for (m in mirrors) {
    message("Trying Ensembl mirror: ", m)
    
    mart <- tryCatch(
      {
        useEnsembl(
          biomart = "genes",
          dataset = "hsapiens_gene_ensembl",
          mirror = m
        )
      },
      error = function(e) NULL
    )
    
    if (!is.null(mart)) {
      message("Connected to mirror: ", m)
      return(mart)
    }
  }
  
  stop("Could not connect to any Ensembl mirror.")
}

